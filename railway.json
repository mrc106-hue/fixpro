{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "node_modules/.bin/next start -p $PORT",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  },
  "nixpacksPlan": {
    "phases": {
      "install": { "cmds": ["npm install"] },
      "build":   { "cmds": ["npm run build"] }
    }
  }
}
